{
  "version": "1.0",
  "rules": [
    {
      "id": "rule-001",
      "description": "Auth module should not import from payment domain",
      "rule_type": "import_boundary",
      "config": { "source_pattern": "src/auth", "forbidden_target": "src/payment" }
    },
    {
      "id": "rule-002",
      "description": "Never use console.log in production source",
      "rule_type": "prohibition",
      "config": { "forbidden_action": "console.log", "scope": "src/production" }
    }
  ]
}
